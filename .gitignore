# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Competition inputs live under data/ (raw CSVs + preprocessed .npy
# arrays + encoder metadata JSON). Generated Kaggle submissions live
# under submissions/. Both directories are per-competition and stay
# untracked — each user pulls their own via scout/bootstrap.
data/*.csv
data/*.npy
data/*.json
data/*.pkl
submissions/*.csv
playground-series-*/

# Experiment logs & results
agent/results.tsv
agent_loop.log
journal/.last_exp_id
harness/.last_training_output

# Scout outputs (generated, not committed)
scout/outputs/

# Agent working files
worktrees/
results/
queue/
dev/
catboost_info/

# TUI local state (generated sprites, saved stream buffers)
.automedal/

# Pi agent auto-installed by automedal (populated on first run)
automedal/_vendor/node_modules/

# Go build outputs
/bin/
*.test

# Stale Python TUI dir (deleted in commit cc54286 but pyc files may regenerate)
/tui/

# Claude Code local config
.claude/

# Graphify outputs for Claude Code
graphify-out/
